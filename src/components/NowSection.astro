---
import { currentFocus, currentRoles } from '../data/profile.js';
---

<section id="now" class="py-6">
  <h2 class="text-2xl font-bold tracking-wide mb-8">Now</h2>
  <p class="mb-6 text-base leading-relaxed">Current professional focus and activities.</p>
  
  <div class="space-y-6">
    <div>
      <h3 class="text-lg font-bold mb-3">Current Roles</h3>
      <ul class="list-disc list-inside space-y-2 text-base">
        {currentRoles.map((role) => <li>{role}</li>)}
      </ul>
    </div>

    <div>
      <h3 class="text-lg font-bold mb-3">Current Focus & Expertise</h3>
      <ul class="list-disc list-inside space-y-2 text-base">
        {currentFocus.map((focus) => <li>{focus}</li>)}
      </ul>
    </div>
  </div>
  
  <p class="text-xs text-gray-500 mt-8 font-mono">Updated: May 10, 2026</p>
</section>
