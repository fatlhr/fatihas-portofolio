---
import { withBasePath } from '../utils/paths.js';

interface Props {
  title: string;
  description: string;
  subtitle?: string;
  githubUrl?: string;
  imageUrl?: string;
  technologies?: string[];
}

const { title, description, subtitle, githubUrl, imageUrl, technologies = [] } = Astro.props;
const imageSrc = imageUrl ? withBasePath(imageUrl) : undefined;
---

<div class="mb-10 flex flex-col sm:flex-row gap-6 sm:gap-8 items-start group">
  <div class="flex-1">
    <a href={githubUrl || "#"} target="_blank" class="inline-block text-lg font-bold text-accent hover:underline decoration-dashed decoration-1 underline-offset-4 mb-1 transition">
      {title}
    </a>
    <div class="flex items-center gap-x-2 text-xs opacity-70 mb-3 font-mono">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
      <span>{subtitle}</span>
    </div>
    <p class="text-sm leading-relaxed">
      {description}
    </p>
    {technologies.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-2">
        {technologies.map((technology) => (
          <li class="border border-current/20 px-2 py-1 text-xs font-mono opacity-80">
            {technology}
          </li>
        ))}
      </ul>
    )}
  </div>
  
  {imageSrc && (
    <a href={githubUrl || "#"} target="_blank" class="block w-full sm:w-1/3 shrink-0 overflow-hidden border border-gray-200/50 hover:border-gray-300 transition-colors">
      <img 
        src={imageSrc}
        alt={`Preview of ${title}`} 
        class="w-full h-auto object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300"
      />
    </a>
  )}
</div>
