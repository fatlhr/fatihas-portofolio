---
import { withBasePath } from '../utils/paths.js';

interface Project {
  slug: string;
  title: string;
  company: string;
  description: string;
  technologies: string[];
  projectLinks?: Array<{
    label: string;
    href: string;
  }>;
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const detailUrl = withBasePath(`projects/${project.slug}`);
const projectLinks = project.projectLinks ?? [];
---

<article class="project-sheet">
  <div class="project-sheet__content">
    <h3 class="project-sheet__title">{project.title}</h3>

    <div class="project-sheet__company">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
      <span>{project.company}</span>
    </div>

    <p class="project-sheet__description">{project.description}</p>

    <ul class="project-sheet__tags">
      {project.technologies.map((technology) => (
        <li>{technology}</li>
      ))}
    </ul>

    {projectLinks.length > 0 && (
      <div class="project-links project-links--home">
        <div class="project-links__list">
          {projectLinks.map((link) => (
            <a
              href={link.href}
              class="project-links__item project-links__item--icon"
              target="_blank"
              rel="noreferrer"
              aria-label={link.label}
              title={link.label}
            >
              {link.label === 'Google Play' ? (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 4l13 8-13 8V4z"/>
                  <path d="M17 12h3"/>
                </svg>
              ) : (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M15.5 3.5c-1 .6-1.8 1.6-2.1 2.8"/>
                  <path d="M8.4 13.4c0-2.8 2-4.5 4.1-4.5 1 0 1.8.3 2.5.8.5.3 1.2.3 1.8 0"/>
                  <path d="M16.2 19.7c-.8.8-1.7 1.3-2.7 1.3s-1.6-.4-2.5-.4-1.6.4-2.5.4c-1 0-1.8-.5-2.6-1.3C4.3 18.1 3 15.4 3 13c0-3.4 2.1-5.7 5.1-5.7"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="project-sheet__footer">
      <a href={detailUrl} class="project-sheet__link">View project note</a>
    </div>
  </div>
</article>
