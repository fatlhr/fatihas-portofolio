---
import { certifications, education, experiences, skills } from '../data/profile.js';
---
<section id="about" class="py-6">
  <h2 class="text-2xl font-bold tracking-wide mb-8">About & Experience</h2>
  
  <div class="space-y-8 text-base leading-relaxed">
    {experiences.map((experience) => (
      <div>
        <h3 class="font-bold">{experience.company}</h3>
        <p class="text-sm italic mb-2 opacity-70">{experience.role} | {experience.period}</p>
        <ul class="list-disc list-inside space-y-1 text-sm">
          {experience.bullets.map((bullet) => <li>{bullet}</li>)}
        </ul>
      </div>
    ))}
  </div>

  <div class="mt-10">
    <h3 class="text-lg font-bold mb-3">Skills & Technologies</h3>
    <p class="text-sm leading-relaxed">
      {skills.join(', ')}.
    </p>
  </div>
  
  <div class="mt-8">
    <h3 class="text-lg font-bold mb-3">Education & Certifications</h3>
    <ul class="list-disc list-inside space-y-1 text-sm">
      {education.map((item) => (
        <li><span class="font-bold">{item.major}</span> - {item.school} ({item.period})</li>
      ))}
      {certifications.map((certification) => <li>{certification}</li>)}
    </ul>
  </div>
</section>
