---
import { withBasePath } from '../utils/paths.js';
---

<header class="main-container py-8 sm:py-10">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <a href={withBasePath()} class="font-mono text-xl sm:text-2xl font-bold hover:opacity-70 transition tracking-tight">
      Mobile Developer
    </a>
    <nav>
      <ul class="flex flex-wrap items-center gap-x-4 gap-y-1 sm:gap-x-6 text-sm font-medium">
        <li><a href={`${withBasePath()}#about`} class="nav-link hover:text-gray-500">About</a></li>
        <li><a href={`${withBasePath()}#projects`} class="nav-link hover:text-gray-500">Projects</a></li>
        <li><a href={withBasePath('blogs/')} class="nav-link hover:text-gray-500">Blogs</a></li>
        <li><a href={`${withBasePath()}#now`} class="nav-link hover:text-gray-500">Now</a></li>
        <li class="flex items-center gap-2 ml-2 sm:ml-4">
          <button id="theme-toggle" aria-label="Theme toggle" class="hover:text-gray-500">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
          </button>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const themeBtn = document.getElementById('theme-toggle');
  themeBtn?.addEventListener('click', () => {
    const element = document.documentElement;
    element.classList.toggle('dark');
    const isDark = element.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
