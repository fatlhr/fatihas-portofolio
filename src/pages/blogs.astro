---
import BaseLayout from '../layouts/BaseLayout.astro';

const blogs = [
  {
    title: "State Management in Flutter: Riverpod vs BLoC",
    date: "May 1, 2026",
    description: "A deep dive into choosing the right state management solution for your next scalable mobile app.",
    url: "/blogs/state-management-flutter"
  },
  {
    title: "Building Responsive UIs in Flutter",
    date: "April 15, 2026",
    description: "Best practices for making your Flutter applications look great on phones, tablets, and web.",
    url: "#"
  },
  {
    title: "CI/CD for Flutter Apps using GitHub Actions",
    date: "March 20, 2026",
    description: "Automate your build and deployment pipelines for Android and iOS.",
    url: "#"
  }
];
---

<BaseLayout title="Blogs - Fatiha Rahmat" description="My thoughts and writings">
  <section class="py-6">
    <h1 class="text-3xl font-bold mb-8 tracking-tight">Blogs</h1>
    <div class="space-y-8">
      {blogs.map((blog) => (
        <div class="mb-6">
          <a href={blog.url} class="inline-block text-lg font-bold text-accent hover:underline decoration-dashed decoration-1 underline-offset-4 mb-1 transition">
            {blog.title}
          </a>
          <div class="flex items-center gap-x-2 text-xs opacity-70 mb-3 font-mono">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            <span>Published: {blog.date}</span>
          </div>
          <p class="text-sm leading-relaxed">
            {blog.description}
          </p>
        </div>
      ))}
    </div>
    <div class="mt-12">
      <a href="/" class="link-underline font-bold text-accent">
        &larr; Back to Home
      </a>
    </div>
  </section>
</BaseLayout>