---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile.js';
import HeroSection from '../components/HeroSection.astro';
import AboutSection from '../components/AboutSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import ResumeSection from '../components/ResumeSection.astro';
import NowSection from '../components/NowSection.astro';
import ContactSection from '../components/ContactSection.astro';

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": profile.name,
  "jobTitle": profile.role,
  "url": "https://fatiharahmat.dev",
  "email": profile.email,
  "sameAs": [profile.linkedin],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Jakarta",
    "addressCountry": "ID"
  },
  "knowsAbout": ["Flutter", "Dart", "Android", "iOS", "Mobile Development", "Riverpod", "BLoC", "Firebase"]
};
---

<BaseLayout
  title={`${profile.name} - ${profile.role}`}
  description={`Portfolio of ${profile.name}, a Flutter mobile engineer with experience across banking, merchant services, lending, agrifood, and freelance projects.`}
  jsonLd={personJsonLd}
>
  <HeroSection />
  <hr />
  <AboutSection />
  <hr />
  <ProjectsSection />
  <hr />
  <ResumeSection />
  <hr />
  <NowSection />
  <hr />
  <ContactSection />
</BaseLayout>
